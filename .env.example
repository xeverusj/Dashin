# Dashin Research Platform — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Required — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your-key-here

# Optional — Streamlit session secret (auto-generated if empty)
FLASK_SECRET_KEY=your-secret-here

# Optional — DeepL translation in cleaner.py
DEEPL_API_KEY=

# Optional — SMTP email notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_NAME=Dashin Research

# Optional — base URL for invite links
DASHIN_BASE_URL=http://localhost:8501

# Optional — super admin alert email
SUPER_ADMIN_EMAIL=admin@dashin.com

# Dashin ingest API — pushes scraper/enricher results into the dashboard.
# The scrapers POST to {DASHIN_API_URL}/api/leads/import with a Bearer token.
# DASHIN_API_URL   : base URL where api_server.py is running (the hosted app),
#                    e.g. https://app.yourdomain.com  or  http://SERVER_IP:8000
# DASHIN_API_TOKEN : a token generated in the dashboard under
#                    Admin → Org Settings → Desktop Scraper Tokens (shown once).
DASHIN_API_URL=http://localhost:8000
DASHIN_API_TOKEN=your_api_token_here
